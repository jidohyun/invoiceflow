# Copy to .env and adjust values. The .env file is git-ignored.

# Host user mapping (prevents root-owned files in mounted volumes)
UID=1000
GID=1000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auto_my_invoice_dev
TEST_POSTGRES_DB=auto_my_invoice_test

# Host port exposed for Postgres (avoids clashing with native 5432 and fishing-pond's 15432)
POSTGRES_PORT=15433

# Phoenix
PHX_PORT=4000
PHX_HOST_BIND=0.0.0.0

# ── Runtime secrets (config/runtime.exs) ──────────────────────────
# Required in prod, optional in dev/test. dev defaults leave each
# unset; the matching client (PaddleClient, VisionClient, etc.)
# short-circuits with a friendly "not configured" log.

# Phoenix release essentials (REQUIRED in prod)
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
# ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=
# Public hostname for url generation (no scheme, no port)
PHX_HOST=

# Paddle Billing
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_PRO=

# OpenAI Vision (OCR)
OPENAI_API_KEY=

# Sentry (error monitoring) — leave blank to disable
SENTRY_DSN=

# AMI-20: CORS — comma-separated allow-list. Leave blank in prod to
# default to :self (same-origin only). Mobile + 3rd-party API users
# should list every domain that ships JS calling /api/v1.
# Examples:
#   CORS_ALLOWED_ORIGINS=https://app.auto-my-invoice.com
#   CORS_ALLOWED_ORIGINS=https://app.auto-my-invoice.com,https://admin.auto-my-invoice.com
#   CORS_ALLOWED_ORIGINS=*   # any origin — logged at boot as a warning
CORS_ALLOWED_ORIGINS=

# ── Mailer (AMI-16) ───────────────────────────────────────────────
# MAILER_ADAPTER controls which Swoosh adapter ships in prod.
#   local → /dev/_mailbox in-browser preview (default for dev)
#   smtp  → Swoosh.Adapters.SMTP via gen_smtp (any SMTP service)
MAILER_ADAPTER=local
MAILER_FROM=noreply@auto-my-invoice.com

# SMTP backend — required when MAILER_ADAPTER=smtp.
# Works with Mailgun / Postmark / SES SMTP endpoint / SendGrid / etc.
MAILER_SMTP_RELAY=smtp.mailgun.org
MAILER_SMTP_USERNAME=
MAILER_SMTP_PASSWORD=
MAILER_SMTP_PORT=587
MAILER_SMTP_SSL=true

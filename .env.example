# Copy to .env and adjust values. The .env file is git-ignored.

# Host user mapping (prevents root-owned files in mounted volumes)
UID=1000
GID=1000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auto_my_invoice_dev
TEST_POSTGRES_DB=auto_my_invoice_test

# Host port exposed for Postgres (avoids clashing with native 5432 and fishing-pond's 15432)
POSTGRES_PORT=15433

# Phoenix
PHX_PORT=4000
PHX_HOST_BIND=0.0.0.0

# ── Runtime secrets (config/runtime.exs) ──────────────────────────
# Required in prod, optional in dev/test. dev defaults leave each
# unset; the matching client (PaddleClient, VisionClient, etc.)
# short-circuits with a friendly "not configured" log.

# Phoenix release essentials (REQUIRED in prod)
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
# ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=
# Public hostname for url generation (no scheme, no port)
PHX_HOST=

# Paddle Billing
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_PRO=

# OpenAI Vision (OCR)
OPENAI_API_KEY=

# Sentry (error monitoring) — leave blank to disable
SENTRY_DSN=

        <a class="text-sm font-medium hover:text-primary transition-colors" href="/users/log_in">Log in</a>
        <a class="btn btn-primary btn-sm rounded-full px-5 shadow-sm" href="/users/register">Get Started</a>
      </div>

      <div class="md:hidden flex items-center">

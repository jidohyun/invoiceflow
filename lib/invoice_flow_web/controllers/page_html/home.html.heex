        <span class="text-primary-content text-xs font-bold uppercase tracking-wider">Most Popular</span>
      </div>
      <div class="p-8">
        <h3 class="text-2xl font-bold text-neutral text-center mb-2">Starter Plan</h3>
        <p class="text-center text-base-content/70 text-sm mb-6">Perfect for freelancers and small agencies.</p>
        <div class="flex justify-center items-baseline mb-8">
          <span class="text-5xl font-display font-extrabold text-neutral">$9</span>
          <span class="text-base-content/70 ml-2">/month</span>
        </div>
        <ul class="space-y-4 mb-8">
          <li class="flex items-center">
            <span class="material-icons text-primary mr-3 text-sm">check</span>
            <span class="text-base-content">Up to 50 active invoices</span>
          </li>
          <li class="flex items-center">
            <span class="material-icons text-primary mr-3 text-sm">check</span>
            <span class="text-base-content">AI OCR Data Extraction</span>
          </li>
          <li class="flex items-center">
            <span class="material-icons text-primary mr-3 text-sm">check</span>
            <span class="text-base-content">Automated 3-Step Reminders</span>
          </li>
          <li class="flex items-center">
            <span class="material-icons text-primary mr-3 text-sm">check</span>
            <span class="text-base-content">Paddle Payment Integration</span>
          </li>
          <li class="flex items-center">
            <span class="material-icons text-primary mr-3 text-sm">check</span>
            <span class="text-base-content">Custom Email Templates</span>
          </li>
        </ul>
        <a class="btn btn-primary btn-block btn-lg rounded-xl font-bold shadow-md" href="/users/register">
          Start 14-Day Free Trial
        </a>
        <p class="text-center text-xs text-base-content/60 mt-4">No credit card required.</p>
      </div>
    </div>
  </div>
</section>

